generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════
// AUTH & USERS
// ═══════════════════════════════════════

enum Role {
  ADMIN
  STUDENT
  NUTRITIONIST
  MASTER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  name           String
  role           Role      @default(STUDENT)
  phone          String?
  avatar         String?
  birthDate      DateTime?
  active         Boolean   @default(true)
  sessionVersion Int       @default(0) // incremented on each login — invalidates previous sessions

  // Endereço
  addressStreet  String?
  addressNumber  String?
  addressComp    String?   // complemento
  addressNeighborhood String?
  addressCity    String?
  addressState   String?
  addressZip     String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  student        Student?        @relation("UserStudent")
  trainerProfile TrainerProfile? @relation("UserTrainer")
  nutritionistProfile NutritionistProfile? @relation("UserNutritionist")
  notifications  Notification[]
  sentMessages     DirectMessage[] @relation("MessageSender")
  receivedMessages DirectMessage[] @relation("MessageReceiver")
}

model TrainerProfile {
  id                 String  @id @default(cuid())
  userId             String  @unique
  bio                String?
  cref               String?
  logo               String?
  brandColor         String  @default("#dc2626")
  gymName            String?
  onboardingComplete Boolean @default(false)
  organizationId     String?

  user      User              @relation("UserTrainer", fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  students  Student[]
  templates WorkoutTemplate[]
  plans     Plan[]
  costs         OperationalCost[]
  scheduleSlots ScheduleSlot[]
  checkIns      CheckIn[]
  leads         Lead[]
  crmTemplates  CrmTemplate[]
  crmWebhooks   CrmWebhook[]
  crmBroadcasts CrmBroadcast[]
  crmBotFlows   CrmBotFlow[]
  knowledge     KnowledgeDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════
// ORGANIZATIONS — Multi-tenant
// ═══════════════════════════════════════

enum OrgStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logo        String?
  domain      String?   @unique
  status      OrgStatus @default(TRIAL)

  // Brand config (overrides branding.ts per org)
  brandConfig Json?

  // Contact
  ownerEmail  String?
  phone       String?
  cnpj        String?

  // SaaS plan limits
  maxProfessionals Int @default(1)
  maxStudents      Int @default(10)

  trainers         TrainerProfile[]
  nutritionists    NutritionistProfile[]
  students         Student[]
  subscriptions    SaasSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
}

model NutritionistProfile {
  id                 String  @id @default(cuid())
  userId             String  @unique
  organizationId     String?
  bio                String?
  crn                String?
  specialty          String?
  logo               String?
  brandColor         String  @default("#10b981")
  onboardingComplete Boolean @default(false)

  user         User          @relation("UserNutritionist", fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  mealPlans    MealPlan[]
  students     Student[]     @relation("StudentNutritionist")
  knowledge    KnowledgeDocument[] @relation("NutriKnowledge")
  leads         Lead[]
  scheduleSlots ScheduleSlot[]
  crmTemplates  CrmTemplate[]
  crmWebhooks   CrmWebhook[]
  crmBroadcasts CrmBroadcast[]
  crmBotFlows   CrmBotFlow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// ═══════════════════════════════════════
// STUDENTS
// ═══════════════════════════════════════

enum StudentStatus {
  ACTIVE
  INACTIVE
  PENDING
}

model Student {
  id           String        @id @default(cuid())
  userId       String        @unique
  trainerId    String?
  organizationId String?
  nutritionistId String?
  birthDate    DateTime?
  gender       Gender?
  weight       Float?
  height       Float?
  goals        String?
  restrictions Json?
  notes        String?
  status       StudentStatus @default(ACTIVE)

  // ── Social Profile ──
  bio          String?   /// Bio pública do perfil (max 150 chars)
  profession   String?   /// Profissão (ex: "Engenheiro de Software", "Designer")
  bioLink      String?   /// Link no perfil (ex: Instagram, LinkedIn)
  lastSeenAt   DateTime? /// Último acesso — online status

  user         User                @relation("UserStudent", fields: [userId], references: [id])
  trainer      TrainerProfile?     @relation(fields: [trainerId], references: [id])
  organization   Organization?        @relation(fields: [organizationId], references: [id])
  nutritionist   NutritionistProfile? @relation("StudentNutritionist", fields: [nutritionistId], references: [id])
  mealPlanAssignments StudentMealPlan[]
  sessions     WorkoutSession[]
  assessments  Assessment[]
  payments     Payment[]
  feedbacks      WorkoutFeedback[]
  workoutPlans   StudentWorkoutPlan[]
  subscriptions  Subscription[]
  communityPosts    CommunityPost[]
  communityReactions CommunityReaction[]
  communityLikes    CommunityLike[]
  communityComments CommunityComment[]
  followers         Follow[]          @relation("Following")
  following         Follow[]          @relation("Follower")
  challengeEntries  ChallengeEntry[]
  bodyScans         BodyScan[]
  nutritionLogs     NutritionLog[]
  pushSubscriptions PushSubscription[]
  progressPhotos    ProgressPhoto[]
  bodyMeasurements  BodyMeasurement[]
  scheduleSlots     ScheduleSlot[]
  extraActivities   ExtraActivity[]
  checkIns          CheckIn[]
  stories           Story[]
  storyViews        StoryView[]
  postViews         PostView[]
  storyHighlights   StoryHighlight[]

  // Spotify OAuth tokens (salvo no DB, não em cookies)
  spotifyAccessToken  String?
  spotifyRefreshToken String?
  spotifyExpiresAt    DateTime?
  spotifyName         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId])
  @@index([organizationId])
  @@index([nutritionistId])
  @@index([status])
  @@index([userId])
}

// ═══════════════════════════════════════
// EXERCISES & LIBRARY
// ═══════════════════════════════════════

model Exercise {
  id           String  @id @default(cuid())
  name         String
  muscle       String
  equipment    String
  gifUrl       String?
  videoUrl     String?
  imageUrl     String?   /// Foto da máquina (link externo: Imgur, Google Drive, etc)
  machineBrand String?   /// Marca/modelo da máquina (ex: "Hammer Strength Iso-Lateral")
  machine3dModel String? /// Slug do modelo 3D .glb (ex: "panatta-leg-press-45" → /models/machines/panatta-leg-press-45.glb)
  instructions String?
  isCustom     Boolean @default(false)

  workoutExercises WorkoutExercise[]

  createdAt DateTime @default(now())

  @@index([muscle])
  @@index([equipment])
}

// ═══════════════════════════════════════
// WORKOUTS & TEMPLATES
// ═══════════════════════════════════════

model WorkoutTemplate {
  id        String  @id @default(cuid())
  name      String
  type      String
  trainerId String
  notes     String?

  trainer      TrainerProfile      @relation(fields: [trainerId], references: [id])
  exercises    WorkoutExercise[]
  sessions     WorkoutSession[]
  workoutPlans StudentWorkoutPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId])
}

/// Técnicas avançadas de treinamento
enum ExerciseTechnique {
  NORMAL
  DROP_SET
  REST_PAUSE
  PYRAMID
  REVERSE_PYRAMID
  FST7
  MYO_REPS
}

model WorkoutExercise {
  id            String  @id @default(cuid())
  templateId    String
  exerciseId    String
  sets          Int
  reps          String
  restSeconds   Int     @default(60)
  loadKg        Float?
  notes         String?
  order            Int
  supersetGroup    String?
  /// Máquina sugerida na academia (ex: "Hammer Strength vermelho, 2ª fileira")
  suggestedMachine String?
  /// Técnica avançada prescrita pelo treinador
  technique        ExerciseTechnique @default(NORMAL)

  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercise Exercise        @relation(fields: [exerciseId], references: [id])

  @@index([templateId])
  @@index([exerciseId])
}

// ═══════════════════════════════════════
// WORKOUT PLANS (assign templates to weekdays)
// ═══════════════════════════════════════

model StudentWorkoutPlan {
  id         String  @id @default(cuid())
  studentId  String
  templateId String
  dayOfWeek  Int     // 0=Domingo, 1=Segunda, ..., 6=Sábado
  active     Boolean @default(true)

  student  Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, dayOfWeek])
  @@index([studentId])
}

// ═══════════════════════════════════════
// WORKOUT SESSIONS (execution by student)
// ═══════════════════════════════════════

model WorkoutSession {
  id          String    @id @default(cuid())
  studentId   String
  templateId  String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  rpe         Int?
  notes       String?
  durationMin Int?

  student  Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  template WorkoutTemplate @relation(fields: [templateId], references: [id])
  sets     SessionSet[]
  feedback WorkoutFeedback?

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([templateId])
  @@index([startedAt])
  @@index([studentId, completedAt])
  @@index([completedAt])
}

model SessionSet {
  id         String            @id @default(cuid())
  sessionId  String
  exerciseId String
  setNumber  Int
  reps       Int
  loadKg     Float
  rpe        Int?
  completed  Boolean           @default(true)
  /// Técnica utilizada na execução real
  technique  ExerciseTechnique @default(NORMAL)
  /// Série extra adicionada pelo aluno (além do prescrito)
  isExtra    Boolean           @default(false)

  session WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([exerciseId])
  @@index([sessionId, exerciseId])
}

// ═══════════════════════════════════════
// AI POST-WORKOUT FEEDBACK
// ═══════════════════════════════════════

enum FeedbackState {
  ACTIVE
  COMPLETED
  ABANDONED
}

model WorkoutFeedback {
  id            String        @id @default(cuid())
  sessionId     String        @unique
  studentId     String
  state         FeedbackState @default(ACTIVE)
  rpe           Int?
  loadChanges   Json?
  painReported  Json?
  energyLevel   String?
  sleepHours    Float?
  nutritionNote String?
  summary       String?
  tokensUsed    Int           @default(0)

  session  WorkoutSession    @relation(fields: [sessionId], references: [id])
  student  Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  messages FeedbackMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
}

model FeedbackMessage {
  id         String @id @default(cuid())
  feedbackId String
  role       String
  content    String
  channel    String @default("app")

  feedback WorkoutFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([feedbackId])
}

// ═══════════════════════════════════════
// ASSESSMENTS
// ═══════════════════════════════════════

enum AssessmentType {
  ANAMNESE
  PAR_Q
  PHYSICAL
  ONE_RM
  SKINFOLD
  CUSTOM
}

model Assessment {
  id        String         @id @default(cuid())
  studentId String
  type      AssessmentType
  title     String?
  data      Json
  photos    Json?
  notes     String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([type])
}

// ═══════════════════════════════════════
// PLANS & SUBSCRIPTIONS
// ═══════════════════════════════════════

enum PlanInterval {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  TRIAL
}

model Plan {
  id          String       @id @default(cuid())
  trainerId   String
  name        String       // ex: "Básico", "Premium", "VIP"
  slug        String?      @unique // ex: "essencial_monthly", "pro_quarterly"
  interval    PlanInterval @default(MONTHLY)
  price       Float
  active      Boolean      @default(true)

  // Feature flags — o que cada plano libera
  hasAI           Boolean @default(false)
  hasPostureCamera Boolean @default(false)
  hasVipGroup     Boolean @default(false)
  hasNutrition    Boolean @default(false)
  maxSessionsWeek Int?    // null = ilimitado

  // B2C flag — planos vendidos diretamente ao consumidor final (sem trainer)
  isB2C       Boolean  @default(false)

  description String?

  trainer       TrainerProfile @relation(fields: [trainerId], references: [id])
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId])
  @@index([isB2C])
}

model Subscription {
  id          String             @id @default(cuid())
  studentId   String
  planId      String
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  endDate     DateTime
  autoRenew   Boolean            @default(true)
  trialEndsAt DateTime?          /// Data de expiração do trial gratuito (B2C)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([planId])
  @@index([status])
  @@index([endDate])
}

// ═══════════════════════════════════════
// FINANCIAL
// ═══════════════════════════════════════

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  CASH
  BANK_TRANSFER
  MERCADOPAGO
}

model Payment {
  id          String        @id @default(cuid())
  studentId   String
  amount      Float
  method      PaymentMethod @default(PIX)
  status      PaymentStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  gatewayId   String?
  description String?
  invoiceUrl  String?

  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reminders PaymentReminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([status])
  @@index([dueDate])
}

// ═══════════════════════════════════════
// OPERATIONAL COSTS
// ═══════════════════════════════════════

enum CostCategory {
  HOSTING        // VPS Coolify
  AI_TOKENS      // Claude API tokens
  SOFTWARE       // Manutenção de software
  GAS            // Gasolina para personal presencial
  EQUIPMENT      // Equipamentos
  MARKETING      // Marketing e publicidade
  OTHER          // Outros custos
}

enum CostRecurrence {
  ONE_TIME       // Custo único
  DAILY          // Diário (ex: tokens IA)
  MONTHLY        // Mensal (ex: hosting)
  QUARTERLY      // Trimestral (ex: manutenção software)
  ANNUAL         // Anual
}

model OperationalCost {
  id          String         @id @default(cuid())
  trainerId   String
  category    CostCategory
  name        String         // "VPS Coolify", "Claude API", "Gasolina", etc.
  amount      Float          // valor em R$
  recurrence  CostRecurrence @default(MONTHLY)
  date        DateTime       @default(now()) // data do custo ou referência
  notes       String?
  active      Boolean        @default(true)  // custos recorrentes ativos

  trainer TrainerProfile @relation(fields: [trainerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId])
  @@index([category])
  @@index([date])
}

// ═══════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════

model Notification {
  id       String  @id @default(cuid())
  userId   String
  type     String
  title    String
  body     String
  read     Boolean @default(false)
  sentVia  Json    @default("[]")
  metadata Json?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}

// ═══════════════════════════════════════
// COMMUNITY — Posts, Reactions, Ranking
// ═══════════════════════════════════════

enum PostType {
  ACHIEVEMENT  // Auto: PR, streak, sessões
  ANNOUNCEMENT // Victor broadcast
  MILESTONE    // Auto: 100 sessões, 1 ano, etc
  USER_POST    // Post livre do aluno (texto + foto)
}

model CommunityPost {
  id        String   @id @default(cuid())
  studentId String?  // null = post do admin/sistema
  type      PostType
  content   String
  imageUrl  String?  // Foto do post (base64 ou URL)
  metadata  Json?    // { exerciseName, oldPR, newPR, streakDays, etc }

  videoUrl  String?  /// Vídeo do post (URL)

  student   Student?           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reactions CommunityReaction[]
  comments  CommunityComment[]
  likes     CommunityLike[]
  views     PostView[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([type])
  @@index([createdAt])
}

enum ReactionType {
  CLAP
  FIRE
  MUSCLE
}

model CommunityReaction {
  id        String       @id @default(cuid())
  postId    String
  studentId String
  type      ReactionType

  post    CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, studentId, type])
  @@index([postId])
}

model CommunityLike {
  id        String @id @default(cuid())
  postId    String
  studentId String

  post    CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, studentId])
  @@index([postId])
}

model CommunityComment {
  id        String @id @default(cuid())
  postId    String
  studentId String
  content   String

  post    CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([createdAt])
}

model PostView {
  id        String @id @default(cuid())
  postId    String
  studentId String

  post    CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  viewedAt DateTime @default(now())

  @@unique([postId, studentId])
  @@index([postId])
}

// ═══════════════════════════════════════
// FOLLOWS — Aluno segue Aluno
// ═══════════════════════════════════════

model Follow {
  id          String @id @default(cuid())
  followerId  String
  followingId String

  follower  Student @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following Student @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ═══════════════════════════════════════
// STORIES — Conteúdo 24h (Instagram-style)
// ═══════════════════════════════════════

model Story {
  id        String   @id @default(cuid())
  studentId String
  imageUrl  String   /// Foto/vídeo do story (base64 ou URL)
  caption   String?  /// Texto opcional sobre o story
  expiresAt DateTime /// Auto-remove após 24h

  student Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  views   StoryView[]

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([expiresAt])
}

model StoryView {
  id        String @id @default(cuid())
  storyId   String
  studentId String

  story   Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  viewedAt DateTime @default(now())

  @@unique([storyId, studentId])
  @@index([storyId])
}

model StoryHighlight {
  id        String @id @default(cuid())
  studentId String
  title     String   /// Nome do highlight (ex: "Treino", "Antes/Depois")
  coverUrl  String   /// Thumbnail do circle
  items     StoryHighlightItem[]

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
}

model StoryHighlightItem {
  id          String @id @default(cuid())
  highlightId String
  imageUrl    String  /// Foto/vídeo do item
  caption     String? /// Texto opcional

  highlight StoryHighlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([highlightId])
}

// ═══════════════════════════════════════
// DIRECT MESSAGES — Victor ↔ Aluno + Peer-to-Peer
// ═══════════════════════════════════════

model DirectMessage {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  readAt     DateTime?
  /// Canal: APP (padrão), WHATSAPP (do aluno), WHATSAPP_BOT (resposta automática)
  channel    String    @default("APP")

  sender   User @relation("MessageSender", fields: [senderId], references: [id])
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

// ═══════════════════════════════════════
// BODY SCAN — Avaliação corporal IA
// ═══════════════════════════════════════

model BodyScan {
  id           String  @id @default(cuid())
  studentId    String
  measurements Json    // { shoulderPx, waistPx, hipPx, legPx, torsoPx }
  ratios       Json    // { shoulderWaist, shoulderHip, waistHip, legTorso }
  bodyShape    String? // "V_SHAPE" | "X_SHAPE" | "TRAPEZOID" | "RECTANGLE" | "PEAR"
  aiAnalysis   String?
  notes        String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([createdAt])
}

// ═══════════════════════════════════════
// CHALLENGES — Desafios semanais
// ═══════════════════════════════════════

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Challenge {
  id          String          @id @default(cuid())
  title       String
  description String?
  metric      String          // "volume_agachamento", "sessoes_semana", "streak_dias"
  targetValue Float?          // meta opcional
  status      ChallengeStatus @default(ACTIVE)
  startDate   DateTime
  endDate     DateTime

  entries ChallengeEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([endDate])
}

model ChallengeEntry {
  id          String @id @default(cuid())
  challengeId String
  studentId   String
  value       Float  @default(0) // valor acumulado na métrica

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([challengeId, studentId])
  @@index([challengeId])
}

// ═══════════════════════════════════════
// NUTRITION — Registro diário de refeições
// ═══════════════════════════════════════

model NutritionLog {
  id            String   @id @default(cuid())
  studentId     String
  date          DateTime @db.Date // um log por dia
  meals         Json     // Meal[] — refeições do dia
  totalCalories Int      @default(0)
  protein       Float    @default(0)
  carbs         Float    @default(0)
  fat           Float    @default(0)
  waterMl       Int      @default(0)
  aiSuggestion  String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([studentId])
  @@index([date])
}

// ═══════════════════════════════════════
// MEAL PLANS — Nutritionist prescriptions
// ═══════════════════════════════════════

enum MealType {
  BREAKFAST
  MORNING_SNACK
  LUNCH
  AFTERNOON_SNACK
  DINNER
  SUPPER
  PRE_WORKOUT
  POST_WORKOUT
}

model MealPlan {
  id              String  @id @default(cuid())
  nutritionistId  String
  name            String
  description     String?
  targetCalories  Int?
  targetProtein   Float?
  targetCarbs     Float?
  targetFat       Float?
  meals           Json
  active          Boolean @default(true)

  nutritionist NutritionistProfile @relation(fields: [nutritionistId], references: [id])
  assignments  StudentMealPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nutritionistId])
}

model StudentMealPlan {
  id         String   @id @default(cuid())
  studentId  String
  planId     String
  active     Boolean  @default(true)
  startDate  DateTime @default(now())
  endDate    DateTime?

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  plan    MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([planId])
}

model Food {
  id          String  @id @default(cuid())
  name        String
  brand       String?
  servingSize Float   @default(100)
  servingUnit String  @default("g")
  calories    Int
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float?
  isCustom    Boolean @default(false)
  createdById String?

  createdAt DateTime @default(now())

  @@index([name])
}

// ═══════════════════════════════════════
// PUSH NOTIFICATIONS — Web Push subscriptions
// ═══════════════════════════════════════

model PushSubscription {
  id        String @id @default(cuid())
  studentId String
  endpoint  String @unique
  p256dh    String
  auth      String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
}

// ═══════════════════════════════════════
// BODY MEASUREMENTS — Circunferências corporais
// ═══════════════════════════════════════

model BodyMeasurement {
  id        String @id @default(cuid())
  studentId String

  // Todas em centímetros (cm), opcionais
  weight     Float?  /// Peso (kg)
  bodyFat    Float?  /// % Gordura corporal
  neck       Float?  /// Pescoço
  chest      Float?  /// Peitoral
  shoulders  Float?  /// Ombros
  leftBicep  Float?  /// Bíceps esquerdo
  rightBicep Float?  /// Bíceps direito
  waist      Float?  /// Cintura
  abdomen    Float?  /// Abdômen
  hips       Float?  /// Quadril
  leftThigh  Float?  /// Coxa esquerda
  rightThigh Float?  /// Coxa direita
  leftCalf   Float?  /// Panturrilha esquerda
  rightCalf  Float?  /// Panturrilha direita
  notes      String? /// Observações

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([createdAt])
}

// PROGRESS PHOTOS — Fotos de evolução (antes/depois)
// ═══════════════════════════════════════

enum PhotoCategory {
  FRONT
  BACK
  SIDE_LEFT
  SIDE_RIGHT
  CUSTOM
}

model ProgressPhoto {
  id         String        @id @default(cuid())
  studentId  String
  imageUrl   String        // URL da foto (upload externo ou base64)
  category   PhotoCategory @default(FRONT)
  weight     Float?        // peso no dia da foto
  bodyFat    Float?        // % gordura (se souber)
  notes      String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([createdAt])
  @@index([category])
}

// ═══════════════════════════════════════
// SCHEDULE — Agenda de sessões
// ═══════════════════════════════════════

enum ScheduleStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum SessionType {
  PRESENCIAL   // treino na academia / in-person
  ONLINE       // videochamada / remoto
  CONSULTORIA  // orientação, plano alimentar, avaliação
}

model ScheduleSlot {
  id             String         @id @default(cuid())
  trainerId      String?
  nutritionistId String?
  studentId      String?        // null = horário livre
  title          String?        // "Treino Força", "Consulta Nutricional", etc
  date           DateTime       // data e hora de início
  duration       Int            @default(60) // duração em minutos
  status         ScheduleStatus @default(SCHEDULED)
  sessionType    SessionType    @default(PRESENCIAL) // modalidade da sessão
  paidOutside    Boolean        @default(false)      // pagou fora do app (pix/dinheiro)
  notes          String?
  recurring      Boolean        @default(false) // se repete toda semana
  color          String?        // cor customizada no calendário

  trainer      TrainerProfile?      @relation(fields: [trainerId], references: [id])
  nutritionist NutritionistProfile? @relation(fields: [nutritionistId], references: [id])
  student      Student?             @relation(fields: [studentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId])
  @@index([nutritionistId])
  @@index([studentId])
  @@index([date])
  @@index([status])
  @@index([sessionType])
}

// ═══════════════════════════════════════
// EXTRA ACTIVITIES — Atividades fora musculação
// ═══════════════════════════════════════

enum ActivityType {
  CARDIO
  RUNNING
  CYCLING
  SWIMMING
  YOGA
  STRETCHING
  HIIT
  SPORT
  OTHER
}

model ExtraActivity {
  id          String       @id @default(cuid())
  studentId   String
  type        ActivityType
  name        String       // "Corrida no parque", "Yoga matinal"
  durationMin Int?         // duração em minutos
  caloriesBurned Int?      // calorias estimadas
  distance    Float?       // distância em km (para corrida/bike)
  heartRateAvg Int?        // FC média
  notes       String?
  date        DateTime     @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([date])
  @@index([type])
}

// ═══════════════════════════════════════
// WORKOUT TEMPLATE LIBRARY — Templates prontos por objetivo
// ═══════════════════════════════════════

enum TemplateGoal {
  HYPERTROPHY
  STRENGTH
  FAT_LOSS
  ENDURANCE
  GENERAL_FITNESS
  REHABILITATION
}

enum TemplateLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model WorkoutTemplateLibrary {
  id          String        @id @default(cuid())
  name        String        // "Push Pull Legs - Hipertrofia"
  description String?
  goal        TemplateGoal
  level       TemplateLevel
  daysPerWeek Int           // quantos dias por semana
  exercises   Json          // array de exercícios com sets/reps/rest
  isPublic    Boolean       @default(true)
  usageCount  Int           @default(0) // quantas vezes foi copiado

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([goal])
  @@index([level])
  @@index([usageCount])
}

// ═══════════════════════════════════════
// PAYMENT REMINDERS — Lembretes de cobrança
// ═══════════════════════════════════════

enum ReminderStatus {
  PENDING
  SENT
  ACKNOWLEDGED
}

model PaymentReminder {
  id        String         @id @default(cuid())
  paymentId String
  channel   String         @default("APP") // APP, PUSH, WHATSAPP
  message   String
  status    ReminderStatus @default(PENDING)
  sentAt    DateTime?
  readAt    DateTime?

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([status])
}

// ═══════════════════════════════════════
// CHECK-IN — QR Code presence tracking
// ═══════════════════════════════════════

model CheckIn {
  id        String   @id @default(cuid())
  studentId String
  trainerId String
  method    String   @default("QR") // QR, MANUAL
  notes     String?

  student Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  trainer TrainerProfile @relation(fields: [trainerId], references: [id])

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([trainerId])
  @@index([createdAt])
}

// ═══════════════════════════════════════
// CRM — Lead management
// ═══════════════════════════════════════

enum LeadStatus {
  NEW
  CONTACTED
  TRIAL
  NEGOTIATING
  CONVERTED
  LOST
}

enum LeadSource {
  WALK_IN
  REFERRAL
  INSTAGRAM
  WHATSAPP
  WEBSITE
  MANYCHAT
  FACEBOOK
  TIKTOK
  OTHER
}

enum LeadTemperature {
  HOT
  WARM
  COLD
}

model Lead {
  id             String          @id @default(cuid())
  trainerId      String?
  nutritionistId String?
  name           String
  phone          String?
  email          String?
  source         LeadSource      @default(OTHER)
  status         LeadStatus      @default(NEW)
  temperature    LeadTemperature @default(COLD)
  notes          String?
  value          Float?          // potential monthly value
  score          Int             @default(0)  // 0-100 AI score
  tags           String[]        // ex: ["bodybuilder", "emagrecimento"]
  lastContactAt  DateTime?
  assignedTo     String?         // team member id
  convertedAt    DateTime?
  lostReason     String?

  trainer        TrainerProfile?       @relation(fields: [trainerId], references: [id])
  nutritionist   NutritionistProfile?  @relation(fields: [nutritionistId], references: [id])
  followUps      LeadFollowUp[]
  activities     CrmActivity[]
  conversations  CrmConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId])
  @@index([nutritionistId])
  @@index([status])
  @@index([temperature])
  @@index([score])
  @@index([createdAt])
}

model LeadFollowUp {
  id      String   @id @default(cuid())
  leadId  String
  type    String   // CALL, WHATSAPP, EMAIL, VISIT, NOTE
  content String
  dueDate DateTime?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([dueDate])
}

// ═══════════════════════════════════════
// CRM — Activities, Templates, Webhooks, Conversations, Broadcasts, Bots
// ═══════════════════════════════════════

model CrmActivity {
  id       String  @id @default(cuid())
  leadId   String
  action   String  // CREATED, STATUS_CHANGED, NOTE_ADDED, SCORED, TEMPERATURE_CHANGED, CONVERTED
  details  String?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

model CrmTemplate {
  id             String   @id @default(cuid())
  trainerId      String?
  nutritionistId String?
  name           String
  content        String
  type           String   @default("whatsapp") // whatsapp, email, sms
  category       String?
  variables      String[] // detected {{var}} placeholders

  trainer      TrainerProfile?      @relation(fields: [trainerId], references: [id])
  nutritionist NutritionistProfile? @relation(fields: [nutritionistId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId])
  @@index([nutritionistId])
}

model CrmWebhook {
  id             String  @id @default(cuid())
  trainerId      String?
  nutritionistId String?
  name           String
  token          String  @unique @default(cuid())
  action         String  @default("create_lead") // create_lead, update_lead, custom
  active         Boolean @default(true)
  config         Json?   // field mapping, default values

  trainer      TrainerProfile?      @relation(fields: [trainerId], references: [id])
  nutritionist NutritionistProfile? @relation(fields: [nutritionistId], references: [id])
  logs         CrmWebhookLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId])
  @@index([nutritionistId])
  @@index([token])
}

model CrmWebhookLog {
  id        String @id @default(cuid())
  webhookId String
  payload   Json
  status    String // success, error
  response  String?

  webhook CrmWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([webhookId])
  @@index([createdAt])
}

model CrmConversation {
  id            String    @id @default(cuid())
  leadId        String
  channel       String    @default("WHATSAPP")
  status        String    @default("OPEN") // OPEN, CLOSED, ARCHIVED
  assignedTo    String?
  unreadCount   Int       @default(0)
  lastMessage   String?
  lastMessageAt DateTime?

  lead     Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages CrmMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([status])
  @@index([lastMessageAt])
}

model CrmMessage {
  id             String  @id @default(cuid())
  conversationId String
  content        String
  fromMe         Boolean @default(false)
  type           String  @default("text") // text, image, audio, document
  status         String  @default("sent") // sent, delivered, read, failed

  conversation CrmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

model CrmBroadcast {
  id             String    @id @default(cuid())
  trainerId      String?
  nutritionistId String?
  name           String
  content        String
  templateId     String?
  status         String    @default("DRAFT") // DRAFT, SENDING, COMPLETED, CANCELLED, FAILED
  filters        Json?     // { statuses[], temperatures[], tags[], minScore }
  sentCount      Int       @default(0)
  failedCount    Int       @default(0)
  scheduledAt    DateTime?

  trainer      TrainerProfile?       @relation(fields: [trainerId], references: [id])
  nutritionist NutritionistProfile?  @relation(fields: [nutritionistId], references: [id])
  recipients   CrmBroadcastRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId])
  @@index([nutritionistId])
  @@index([status])
}

model CrmBroadcastRecipient {
  id          String    @id @default(cuid())
  broadcastId String
  leadId      String
  status      String    @default("pending") // pending, sent, delivered, read, failed
  sentAt      DateTime?

  broadcast CrmBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([broadcastId])
  @@index([status])
}

model CrmBotFlow {
  id             String  @id @default(cuid())
  trainerId      String?
  nutritionistId String?
  name           String
  trigger        String  @default("new_lead") // new_lead, keyword, status_change, manual
  nodes          Json    @default("[]")
  edges          Json    @default("[]")
  active         Boolean @default(false)

  trainer      TrainerProfile?      @relation(fields: [trainerId], references: [id])
  nutritionist NutritionistProfile? @relation(fields: [nutritionistId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId])
  @@index([nutritionistId])
  @@index([active])
}

// ═══════════════════════════════════════
// AI Token Usage — tracking real de consumo Groq
// ═══════════════════════════════════════

model AiTokenUsage {
  id             String   @id @default(cuid())
  model          String   // llama-3.3-70b-versatile, llama-3.2-11b-vision-preview
  feature        String   // chat, lead_bot, post_workout, scoring, workout_gen, anamnesis, engagement, body_scan
  promptTokens   Int      @default(0)
  completionTokens Int    @default(0)
  totalTokens    Int      @default(0)
  latencyMs      Int?     // tempo de resposta
  success        Boolean  @default(true)
  error          String?

  createdAt DateTime @default(now())

  @@index([feature])
  @@index([model])
  @@index([createdAt])
}

// ═══════════════════════════════════════
// RAG — Knowledge Base for AI
// ═══════════════════════════════════════

enum KnowledgeCategory {
  EXERCISE       // Exercícios — execução, biomecânica, variações
  MACHINE        // Máquinas — manuais, ajustes, uso correto
  POSTURE        // Postura — correção, alinhamento, ângulos
  NUTRITION      // Nutrição — dietas, macros, suplementos
  SCIENCE        // Ciência — artigos, estudos, evidências
  PROTOCOL       // Protocolos — periodização, métodos de treino
  INJURY         // Lesões — prevenção, reabilitação, contraindicações
  GENERAL        // Geral — outros conhecimentos fitness
}

model Machine3D {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  file      String   // path relativo: /models/machines/xxx.glb
  videoUrl  String?
  addedAt   DateTime @default(now())

  @@index([slug])
}

model KnowledgeDocument {
  id          String            @id @default(cuid())
  trainerId   String
  title       String
  content     String            // texto do documento
  category    KnowledgeCategory @default(GENERAL)
  tags        String[]          // tags de busca (ex: ["supino", "peitoral", "victor-personal"])
  imageUrl    String?           // foto/infográfico associado
  sourceUrl   String?           // link do artigo original
  embedding   Float[]           // Google text-embedding-004 = 768 dims, stored as JSON array

  trainer     TrainerProfile @relation(fields: [trainerId], references: [id])
  nutritionistId String?
  nutritionist   NutritionistProfile? @relation("NutriKnowledge", fields: [nutritionistId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([trainerId])
  @@index([category])
}

// ═══════════════════════════════════════
// SAAS CRM — Platform sales pipeline
// ═══════════════════════════════════════

enum SaasLeadStatus {
  NEW
  CONTACTED
  DEMO_SCHEDULED
  DEMO_DONE
  NEGOTIATING
  CONVERTED
  LOST
}

enum SaasLeadType {
  ACADEMY
  PERSONAL_TRAINER
  NUTRITIONIST
  CLINIC
}

model SaasLead {
  id                String         @id @default(cuid())
  name              String
  email             String?
  phone             String?
  company           String?
  type              SaasLeadType   @default(ACADEMY)
  status            SaasLeadStatus @default(NEW)
  notes             String?
  city              String?
  state             String?
  estimatedStudents Int?
  estimatedMrr      Float?
  source            String?
  score             Int?
  temperature       String   @default("COLD") // HOT, WARM, COLD
  lostReason        String?
  convertedAt       DateTime?
  convertedOrgId    String?

  followUps SaasLeadFollowUp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([temperature])
}

model SaasLeadFollowUp {
  id      String    @id @default(cuid())
  leadId  String
  type    String
  content String
  dueDate DateTime?

  lead SaasLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([leadId])
}

// ═══════════════════════════════════════
// SAAS BILLING — Platform subscription management
// ═══════════════════════════════════════

enum SaasPlanInterval {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

model SaasPlan {
  id               String           @id @default(cuid())
  name             String
  price            Float
  interval         SaasPlanInterval @default(MONTHLY)
  maxProfessionals Int              @default(1)
  maxStudents      Int              @default(10)
  features         Json?
  active           Boolean          @default(true)

  subscriptions SaasSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SaasSubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELLED
  EXPIRED
}

model SaasSubscription {
  id             String                 @id @default(cuid())
  organizationId String
  planId         String
  status         SaasSubscriptionStatus @default(TRIAL)
  startDate      DateTime               @default(now())
  endDate        DateTime?
  trialEndsAt    DateTime?
  cancelledAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  plan         SaasPlan     @relation(fields: [planId], references: [id])
  invoices     SaasInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

model SaasInvoice {
  id             String   @id @default(cuid())
  subscriptionId String
  amount         Float
  status         String   @default("pending")
  dueDate        DateTime
  paidAt         DateTime?
  referenceMonth String

  subscription SaasSubscription @relation(fields: [subscriptionId], references: [id])

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
}

// ═══════════════════════════════════════════════════════════════
// PLATFORM SETTINGS — key/value pra configs do painel master
// ═══════════════════════════════════════════════════════════════

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// MASTER COSTS — Platform-level operational costs (SaaS business)
// ═══════════════════════════════════════════════════════════════

model MasterCost {
  id         String   @id @default(cuid())
  category   String   // AI_TOKENS, HOSTING, WHATSAPP, DOMAINS, SOFTWARE, MARKETING, LEGAL, TEAM, OTHER
  name       String
  amount     Float
  recurrence String   @default("MONTHLY") // ONE_TIME, MONTHLY, ANNUAL
  active     Boolean  @default(true)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([active])
}

// ═══════════════════════════════════════════════════════════════
// TRANSACTION LOG — Anti-fraud audit trail for payment events
// ═══════════════════════════════════════════════════════════════

model TransactionLog {
  id          String   @id @default(cuid())
  type        String   // checkout_created, payment_received, payment_verified, fraud_flagged, refund
  amount      Float
  email       String
  planId      String?
  gatewayId   String?  // Mercado Pago payment ID
  ip          String?
  userAgent   String?
  riskLevel   String?  // low, medium, high
  flags       Json?    // ["amount_mismatch", "suspicious_email", etc]
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([type])
  @@index([gatewayId])
  @@index([createdAt])
}
